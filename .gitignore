######################################################################
# .gitignore for a TwinCAT 3 (Beckhoff) PLC + visualization project
# Tracked as source: *.plcproj, *.tsproj, *.TcPOU, *.TcGVL, *.TcDUT,
#                    *.TcVIS, *.TcTTO, *.xti, *.sln
# Based on Beckhoff's TC3 source-control manual + github/gitignore
######################################################################

# ----------------------------- TwinCAT PLC -----------------------------
*.tpy
*.tclrs
*.tclrq
*.library
*.compiled-library
# *.compileinfo is regenerated on download; needed only for core-dump analysis
*.compileinfo
*.bootinfo
*.bootinfo_guids
*.asm
*.core
# CODESYS/TwinCAT temporary "unsaved project" file (e.g. kayma.~u)
*.~u
LineIDs.dbg
LineIDs.dbg.bak

# --------------------- TwinCAT C++ / shared types ----------------------
# Ignoring *.tmc is only safe for PLAIN PLC projects. If you add C++,
# TcCOM modules, or share data types via TMC, REMOVE the *.tmc line below
# (comment it out) so the file gets committed.
*.tmc
*.tmcRefac

# ------------------------ TwinCAT project backups ----------------------
*.plcproj.bak
*.plcproj.orig
*.tsproj.bak
*.tsproj.b?k
*.tsproj.orig
*.tspproj.bak
*.xti.bak
*.xti.bk?
*.xti.orig
*.xtv
*.xtv.bak
*.xtv.bk?
*.xt?.bk?
*.xt?.orig
*.tnzip
*.tpzip
*.tszip

# ----------------------------- Multiuser -------------------------------
**/.TcGit/

# --------------------- Generated / output folders ----------------------
**/_Boot/
**/_CompileInfo/
**/_Libraries/
**/_ModuleInstall/
**/_Deployment/
**/_Repository/
# To keep a specific (e.g. third-party) library folder, re-include it:
#   !/**/_Libraries/<directory name>/

# ----------------- TwinCAT HMI (TF2000) – if you use it ----------------
**/.engineering_servers/
**/.hmiframework/
**/.hmipkgs/
liveview_*
liveview*.html
*.db-shm
*.db-wal
*.pid
tchmipublish.journal.json
blob_storage/
Packages/

# --------------------- Visual Studio / XAE shell -----------------------
.vs/
*.rsuser
*.suo
*.user
*.userosscache
*.userprefs
*.sln.docstates
*.VC.db
*.VC.VC.opendb
_UpgradeReport_Files/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/

# ------------------------------ NuGet ----------------------------------
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# ------------------------------- OS junk -------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
